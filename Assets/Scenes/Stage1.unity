--- !u!114 &948291057
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 948291055}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 746d5ce46eceabd4ca32926300207574, type: 3}
    m_FontSize: 35
    m_FontStyle: 1
    m_BestFit: 0
    m_MinSize: 3
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "[\uAE30\uBCF8 \uC870\uC791\uBC95]\n\uD654\uC0B4\uD45C \uC88C\uC6B0 \uD0A4\uB85C
    \uC5EC\uC6B0\uB97C \uC870\uC791\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\uC2A4\uD398\uC774\uC2A4
    \uBC14\uB97C \uB204\uB974\uBA74 \uC810\uD504\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\nESC
    \uD0A4\uB97C \uB204\uB974\uBA74 \uC77C\uC2DC\uC815\uC9C0\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\n\uC801\uC758
    \uBA38\uB9AC\uB97C \uBC1F\uC73C\uBA74 \uC801\uC744 \uD574\uCE58\uC6B8 \uC218
    \uC788\uC2B5\uB2C8\uB2E4.\n\n\n[\uD074\uB9AC\uC5B4 \uC870\uAC74]\n\u25CF \uBC18\uB4DC\uC2DC
    \uB9F5\uC5D0 \uC788\uB294 \uBAA8\uB4E0 \uCCB4\uB9AC\uB97C \uD68D\uB4DD\uD558\uACE0
    \uC9D1\uC73C\uB85C \uB3CC\uC544\uC640\uC57C \uD074\uB9AC\uC5B4\uB429\uB2C8\uB2E4.\n\u25CF
    \uC82C\uC740 \uC810\uC218\uC5D0\uB9CC \uAD00\uC5EC\uD558\uBA70 \uD074\uB9AC\uC5B4
    \uC870\uAC74\uC740 \uC544\uB2D9\uB2C8\uB2E4.\n\u25CF \uAC00\uC2DC\uC640 \uC801\uC5D0\uAC8C
    3\uBC88 \uD53C\uD574\uB97C \uC785\uC73C\uBA74 \uAC8C\uC784 \uC624\uBC84\uC785\uB2C8\uB2E4.\n\n\n\n\uADF8\uB7FC
    \uC5EC\uC6B0\uAC00 \uBB34\uC0AC\uD788 \uCCB4\uB9AC\uB97C \uC5BB\uACE0 \uC9D1\uC73C\uB85C
    \uB3CC\uC544\uAC08 \uC218 \uC788\uAC8C \uB3C4\uC640\uC8FC\uC138\uC694!"
