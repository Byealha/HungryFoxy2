--- !u!114 &1255067538
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1255067536}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 746d5ce46eceabd4ca32926300207574, type: 3}
    m_FontSize: 30
    m_FontStyle: 1
    m_BestFit: 0
    m_MinSize: 3
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\uAC8C\uC784\uC758 \uAE30\uB2A5 \uCD94\uAC00\uB3C4 \uAE30\uB2A5 \uCD94\uAC00\uC774\uC9C0\uB9CC
    \uC800\uB294 \uB514\uD14C\uC77C\uC744 \uC911\uC2EC\uC73C\uB85C \uAC1C\uBC1C\uD588\uC2B5\uB2C8\uB2E4.\n\n\uC0AC\uC18C\uD55C
    \uBD80\uBD84\uC5D0\uC11C \uC2E0\uACBD \uC4F4 \uBD80\uBD84\uC774 \uB9CE\uC73C\uBA70,
    \uCD5C\uB300\uD55C \uBC84\uADF8 \uC5C6\uC774 \uB9CC\uB4DC\uB294 \uAC83\uC744
    \uBAA9\uD45C\uB85C \uD558\uC600\uC2B5\uB2C8\uB2E4.\n\uB610\uD55C \uC2DC\uAC01\uC801\uC778
    \uC694\uC18C\uC640 \uAC8C\uC784 \uD50C\uB808\uC774\uB85C\uC368 \uAE30\uCD08\uAC00
    \uB41C\uB2E4\uB77C\uACE0 \uC0DD\uAC01\uB418\uB294 \uC694\uC18C\uB4E4\uC740 \uCD5C\uB300\uD55C\n\uAD6C\uD604\uD574\uBCF4\uC558\uC2B5\uB2C8\uB2E4.
    \n\n\uD639\uC2DC \uB0B4\uC6A9\uC774 \uAD81\uAE08\uD558\uC2DC\uB2E4\uBA74 \uC601\uC0C1\uC744
    \uC77C\uC2DC\uC815\uC9C0\uD574\uC11C \uBCF4\uC2DC\uBA74 \uB418\uACA0\uC2B5\uB2C8\uB2E4.\n\n\uAC10\uC0AC\uD569\uB2C8\uB2E4.\n\n[v
    1.0]\n\uAC8C\uC784\uC758 \uD070\uD2C0\uC744 \uB9CC\uB4E4\uC5C8\uC2B5\uB2C8\uB2E4.\n\u25CF
    \uCE90\uB9AD\uD130\uC758 \uC774\uB3D9 \uBC0F \uC810\uD504 \uAD6C\uD604\n\u25CF
    TileMap\uC744 \uD1B5\uD55C \uD50C\uB7AB\uD3EC\uBA38 \uAD6C\uCD95\n\u25CF \uBAAC\uC2A4\uD130\uC758
    \uC774\uB3D9 \uBC0F \uB370\uBBF8\uC9C0, \uCC98\uCE58 \uAE30\uB2A5 \uAD6C\uD604\n\u25CF
    \uCCB4\uB9AC\uC640 \uC7BC \uC544\uC774\uD15C \uCD94\uAC00 \uBC0F \uD68D\uB4DD
    \uAE30\uB2A5 \uAD6C\uD604\n\u25CF \uCCB4\uB9AC \uC544\uC774\uD15C \uBAA8\uB450
    \uD68D\uB4DD \uD6C4 \uC9D1 \uC624\uBE0C\uC81D\uD2B8\uC5D0 \uCDA9\uB3CC\uC2DC
    OnTrigger\uAE30\uB2A5\uC744 \uC774\uC6A9\uD55C \uC2A4\uD14C\uC774\uC9C0 \uD074\uB9AC\uC5B4\n\u25CF
    \uCCB4\uB9AC\uC640 \uC7BC \uC544\uC774\uD15C \uD68D\uB4DD\uC2DC \uC0C1\uB2E8\uC5D0
    \uCE74\uC6B4\uD2B8\n\u25CF \uCCB4\uB9AC\uB97C \uBAA8\uB450 \uBAA8\uC73C\uC9C0\uC54A\uACE0
    \uC9D1\uACFC \uC0C1\uD638\uC791\uC6A9\uD558\uBA74 \uC54C\uB9BC \uBC1C\uC0DD\n\u25CF
    \uBAAC\uC2A4\uD130\uC640 \uCDA9\uB3CC\uC2DC \uCCB4\uB825 \uC18C\uBAA8 (0\uAC1C\uC2DC
    \uC0AC\uB9DD / \uC0AC\uB9DD \uC2DC \uC0C1\uB2E8\uC5D0 \uC0AC\uB9DD \uBB38\uAD6C\uAC00
    \uB738, R\uD0A4\uB85C \uC7AC\uC2DC\uC791)\n\u25CF \uD6A8\uACFC\uC74C \uCD94\uAC00\n\n"
