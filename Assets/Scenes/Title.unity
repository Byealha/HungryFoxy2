--- !u!114 &1491785515
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1491785513}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 746d5ce46eceabd4ca32926300207574, type: 3}
    m_FontSize: 30
    m_FontStyle: 1
    m_BestFit: 0
    m_MinSize: 3
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "[v 1.1]\n\uAC8C\uC784\uC758 \uC804\uCCB4\uC801\uC778 \uC9C4\uD589 \uD750\uB984\uC774
    \uC790\uC5F0\uC2A4\uB7FD\uAC8C \uB9CC\uB4E4\uC5C8\uC2B5\uB2C8\uB2E4.\n\u25CF
    \uD0C0\uC774\uD2C0 \uD654\uBA74 \uC52C \uCD94\uAC00\n\u25CF \uD0C0\uC774\uD2C0
    \uD654\uBA74\uC740 \uBB34\uD55C \uC2A4\uD06C\uB864 \uBC30\uACBD\uC744 \uC774\uC6A9\uD558\uC5EC
    \uC5EC\uC6B0\uAC00 \uACC4\uC18D\uD574\uC11C \uB2EC\uB9AC\uB294 \uB4EF\uD55C \uC5F0\uCD9C\n\u25CF
    \uC751\uC6A9\uD558\uC5EC \uD0C0\uC774\uD2C0 \uD654\uBA74\uC758 TileMap\uB3C4
    \uACC4\uC18D\uD574\uC11C \uBB34\uD55C \uC2A4\uD06C\uB864 \uB418\uB3C4\uB85D \uC5F0\uCD9C\n\u25CF
    \uD0C0\uC774\uD2C0 \uD654\uBA74\uC5D0\uC11C <\uAC8C\uC784 \uC2DC\uC791> \uD074\uB9AD\uC2DC
    \uD50C\uB7AB\uD3EC\uBA38 \uB9F5\uC73C\uB85C \uC774\uB3D9\n\u25CF \uC52C\uACFC
    \uC52C \uC774\uB3D9 \uC0AC\uC774\uC5D0 \uCF54\uB8E8\uD2F4\uC744 \uC774\uC6A9\uD55C
    \uD398\uC774\uB4DC \uC778 / \uC544\uC6C3 \uAE30\uB2A5 \uAD6C\uD604\n\u25CF \uD0C0\uC774\uD2C0
    \uD654\uBA74\uC5D0\uC11C <\uAC8C\uC784 \uC885\uB8CC> \uD074\uB9AD\uC2DC \uAC8C\uC784
    \uC885\uB8CC\n\u25CF \uC0AC\uB9DD \uC5F0\uCD9C \uBCC0\uACBD (\uC0AC\uB9DD \uBB38\uAD6C\uAC00
    \uB728\uACE0 \uD398\uC774\uB4DC \uC544\uC6C3 \uC5F0\uCD9C\uC774 \uB728\uB3C4\uB85D
    \uBCC0\uACBD)\n\u25CF \uBC30\uACBD\uC74C \uCD94\uAC00\n\n[v 1.2]\n\uAC8C\uC784\uC774
    \uC720\uB2C8\uB7F0\uACFC \uB108\uBB34 \uB2E4\uB978 \uBC29\uD5A5\uC744 \uAC00\uB294
    \uAC83 \uAC19\uC544 \uC720\uB2C8\uB7F0\uACFC \uBE44\uC2B7\uD55C \uC2A4\uD14C\uC774\uC9C0\uB97C
    \uAC1C\uBC1C\uD588\uC2B5\uB2C8\uB2E4.\n\u25CF \uC2A4\uD14C\uC774\uC9C0 2 \uCD94\uAC00\n\u25CF
    \uCE90\uB9AD\uD130\uB294 \uB2EC\uB9AC\uB294 \uC560\uB2C8\uBA54\uC774\uC158\uC744
    \uC2E4\uD589\uD558\uACE0, \uD50C\uB7AB\uD3EC\uBA38\uC758 x \uC88C\uD45C\uAC00
    -\uBC29\uD5A5\uC73C\uB85C \uC774\uB3D9\uD558\uB294 \uBC29\uC2DD\n\u25CF \uBC30\uACBD\uC740
    \uD0C0\uC774\uD2C0\uC5D0\uC11C \uB9CC\uB4E0 \uBB34\uD55C \uC2A4\uD06C\uB864 \uC751\uC6A9\n\u25CF
    \uCE90\uB9AD\uD130\uC758 \uB354\uBE14 \uC810\uD504 \uAD6C\uD604\n\u25CF \uB9F5
    \uACF3\uACF3\uC5D0 \uCCB4\uD06C\uD3EC\uC778\uD2B8 \uB85C\uC9C1 \uAD6C\uD604\n\u25CF
    \uCE90\uB9AD\uD130\uAC00 \uCD94\uB77D\uC2DC \uB9C8\uC9C0\uB9C9 \uCCB4\uD06C\uD3EC\uC778\uD2B8\uC758
    OnTrigger \uC7A5\uC18C\uB85C \uC774\uB3D9\n\u25CF \uC774\uB3D9\uD558\uB294 \uC5F0\uCD9C\uC740
    \uCF54\uB8E8\uD2F4\uC744 \uD65C\uC6A9\uD558\uC5EC \uC815\uC9C0 > \uD654\uBA74
    \uB4A4\uB85C \uC2A4\uD06C\uB864 > \uCCB4\uD06C\uD3EC\uC778\uD2B8 \uBD80\uD65C"
