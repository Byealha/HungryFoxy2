    \uB728\uB3C4\uB85D \uAD6C\uD604\n\u25CF \uC2A4\uD14C\uC774\uC9C0 \uD074\uB9AC\uC5B4
    \uC2DC \uBC30\uACBD\uC74C\uC545 \uBCC0\uACBD\n\u25CF \uC2A4\uD14C\uC774\uC9C0
    2\uC5D0\uC11C\uB294 \uB3C4\uCC29\uC9C0\uC810\uC5D0 \uADFC\uC811\uD560 \uC2DC
    \uCCB4\uB9AC\uB97C \uC790\uB3D9\uC73C\uB85C \uBA39\uB294 \uC5F0\uCD9C \uCD94\uAC00\n\u25CF
    \uD0C0\uC774\uD2C0 \uD654\uBA74\uC5D0 <\uC124\uC815> \uCD94\uAC00\n\u25CF <\uC124\uC815>
    \uD074\uB9AD \uC2DC \uBC30\uACBD\uC74C\uACFC \uD6A8\uACFC\uC74C \uC870\uC808
    \uAC00\uB2A5\n\n[v 1.6]\n\uBC84\uADF8 \uC218\uC815 \uBC0F \uC548\uC815\uD654\n\u25CF
    \uC2A4\uD14C\uC774\uC9C0 \uC785\uC7A5 \uC5F0\uCD9C \uC911 \uC88C\uC6B0\uB85C
    \uC6C0\uC9C1\uC77C \uC218 \uC788\uB358 \uC624\uB958 \uC218\uC815\n\u25CF \uC2A4\uD14C\uC774\uC9C0
    \uC785\uC7A5 \uC5F0\uCD9C \uC911 \uC2A4\uD398\uC774\uC2A4 \uBC14 \uC5F0\uD0C0\uC2DC
    \uD398\uC774\uB4DC \uC544\uC6C3\uC774 \uC5F0\uC18D\uC73C\uB85C \uB418\uB358 \uC624\uB958
    \uC218\uC815\n\u25CF \uCCB4\uB9AC\uB97C \uB2E4 \uBAA8\uC73C\uC9C0 \uC54A\uACE0
    \uC9D1\uC5D0 \uB3CC\uC544\uAC14\uC744 \uB54C \uC9D1 \uC624\uBE0C\uC81D\uD2B8\uC640
    \uC5F0\uC18D\uC73C\uB85C \uC0C1\uD638\uC791\uC6A9\uD558\uBA74 \uD14D\uC2A4\uD2B8
    \uC624\uB958\uAC00 \uC77C\uC5B4\uB098\uB358 \uC624\uB958 \uC218\uC815\n\u25CF
    \uBAAC\uC2A4\uD130 \uCC98\uCE58 \uD310\uC815\uC774 \uAC00\uB054 \uC774\uC0C1\uD558\uAC8C
    \uB3D9\uC791\uB418\uB358 \uC624\uB958 \uC218\uC815\n\u25CF \uCE90\uB9AD\uD130\uAC00
    \uBCBD\uC5D0 \uBE44\uBE44\uBA74 \uB099\uD558 \uC18D\uB3C4\uAC00 \uB290\uB824\uC9C0\uB358
    \uC624\uB958 \uC218\uC815\n"
